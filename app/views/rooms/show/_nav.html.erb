<% content_for :nav do %>
  <%= account_logo_tag if Current.account.logo.attached? %>

  <%= tag.span class: "btn btn--reversed btn--faux room--current" do %>
    <h1 class="room__contents txt-medium overflow-ellipsis">
      <% if room.direct? %>
        <span class="for-screen-reader">Ping with</span>
      <% end %>

      <%= room_display_name(room) %>
    </h1>
  <% end %>

  <%= link_to_edit_room(room) do %>
    <%= image_tag "menu-dots-horizontal.svg", size: 20, aria: { hidden: "true" } %>
    <span class="for-screen-reader">Settings for this <%= room.direct? ? "Ping" : "room" %></span>
  <% end %>

  <%= render "rooms/involvements/bell", room: room %>

  <div class="theme-toggle" data-controller="theme" role="radiogroup" aria-label="Theme">
    <button class="btn theme-toggle__btn" data-theme-target="lightBtn" data-action="theme#select" data-theme-theme-param="light" role="radio" aria-checked="false" aria-label="Light theme">
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/></svg>
    </button>
    <button class="btn theme-toggle__btn" data-theme-target="darkBtn" data-action="theme#select" data-theme-theme-param="dark" role="radio" aria-checked="false" aria-label="Dark theme">
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
    </button>
    <button class="btn theme-toggle__btn" data-theme-target="systemBtn" data-action="theme#select" data-theme-theme-param="system" role="radio" aria-checked="false" aria-label="System theme">
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.07.28.106.424A1 1 0 0112.108 17H7.892a1 1 0 01-.97-1.243l.3-1.196H5a2 2 0 01-2-2V5zm2 0h10v8H5V5z" clip-rule="evenodd"/></svg>
    </button>
  </div>

  <% doc_room_name = room.direct? ? "DM: #{room.users.map(&:name).sort.join(' & ')}" : room_display_name(room) %>
  <div class="documents-wrapper" data-controller="documents" data-documents-room-id-value="<%= room.id %>" data-documents-room-name-value="<%= doc_room_name %>">
    <button class="btn documents-icon-btn" data-documents-target="icon" data-action="click->documents#toggle" title="Documents">
      <svg class="icon documents-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14,2 14,8 20,8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10,9 9,9 8,9"/>
      </svg>
      <span class="for-screen-reader">Documents</span>
    </button>
    <%= render "rooms/documents_dropdown", room: room %>
  </div>
<% end %>

<%= render "rooms/document_preview" %>
