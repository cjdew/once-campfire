<% content_for :nav do %>
  <%= account_logo_tag if Current.account.logo.attached? %>

  <%= tag.span class: "btn btn--reversed btn--faux room--current" do %>
    <h1 class="room__contents txt-medium overflow-ellipsis">
      <% if room.direct? %>
        <span class="for-screen-reader">Ping with</span>
      <% end %>

      <%= room_display_name(room) %>
    </h1>
  <% end %>

  <%= link_to_edit_room(room) do %>
    <%= image_tag "menu-dots-horizontal.svg", size: 20, aria: { hidden: "true" } %>
    <span class="for-screen-reader">Settings for this <%= room.direct? ? "Ping" : "room" %></span>
  <% end %>

  <%= render "rooms/involvements/bell", room: room %>

  <% doc_room_name = room.direct? ? "DM: #{room.users.map(&:name).sort.join(' & ')}" : room_display_name(room) %>
  <div class="documents-wrapper" data-controller="documents" data-documents-room-id-value="<%= room.id %>" data-documents-room-name-value="<%= doc_room_name %>">
    <button class="documents-icon-btn" data-documents-target="icon" data-action="click->documents#toggle" title="Documents">
      <svg class="icon documents-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14,2 14,8 20,8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10,9 9,9 8,9"/>
      </svg>
    </button>
    <%= render "rooms/documents_dropdown", room: room %>
  </div>
<% end %>

<%= render "rooms/document_preview" %>
